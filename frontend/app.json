{
  "expo": {
    "name": "Flow — Life, but easier.",
    "slug": "flow-daily-life-os",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "flow",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "description": "Your calm AI daily co-pilot. Real weather, tiny decisions, and a quieter day — all in one place.",
    "primaryColor": "#000000",
    "backgroundColor": "#000000",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.flowapp.daily",
      "buildNumber": "1.1.0",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Flow uses your location to show live weather and outfit suggestions.",
        "NSMicrophoneUsageDescription": "Flow uses your microphone only when you tap to talk to the AI assistant.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.flowapp.daily",
      "versionCode": 3,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "RECORD_AUDIO",
        "INTERNET",
        "VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 160,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Flow uses your location to show live weather and outfit suggestions."
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "supportEmail": "hello@flowapp.daily",
      "legalWebsite": "https://flowapp.daily"
    }
  }
}
